# Скопируй этот файл в .env и подставь свои значения.
# .env лежит в .gitignore — никогда не коммить настоящий ключ.

# === Telegram ===
# Получить у @BotFather: /newbot или /token
TELEGRAM_TOKEN=123456789:ABC-your-bot-token-here

# === Groq API ===
# Получить на console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_...ваш-ключ...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30
GROQ_MAX_TOKENS=300

# === Настройки магазина ===
SHOP_NAME=Магазин техники

# === Параметры генерации ===
TEMPERATURE=0.6
TOP_P=0.9

# === Поведение бота ===
MAX_RETRIES=3
RETRY_DELAY=1
MAX_MESSAGE_LENGTH=4096
LOG_LEVEL=INFO
