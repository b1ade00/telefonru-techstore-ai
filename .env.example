# Скопируй этот файл в .env и подставь свои значения.
# .env лежит в .gitignore — никогда не коммить настоящий токен.

# === Telegram ===
# Получить у @BotFather: /newbot или /token
TELEGRAM_TOKEN=123456789:ABC-your-bot-token-here

# === LM Studio (локальная LLM) ===
# Запусти LM Studio → Developer → Status: Running
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=qwen2.5-14b-instruct
LM_STUDIO_TIMEOUT=600
LM_STUDIO_MAX_TOKENS=300

# === Параметры генерации ===
TEMPERATURE=0.6
TOP_P=0.9

# === Поведение бота ===
MAX_RETRIES=1
RETRY_DELAY=1
MAX_MESSAGE_LENGTH=4096
LOG_LEVEL=INFO
